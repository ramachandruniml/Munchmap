# Copy to .env and fill in values

ENVIRONMENT=development

# Supabase project (Settings -> API, Settings -> Database -> Connection string)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Pooled ("Transaction" mode) connection string, with the driver swapped to asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:[password]@[host]:6543/postgres

REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

ANTHROPIC_API_KEY=

NEXT_PUBLIC_API_URL=http://localhost:8000
